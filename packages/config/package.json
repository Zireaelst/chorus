{
  "name": "@chorus/config",
  "version": "0.0.1",
  "private": true,
  "description": "Shared ESLint, TypeScript, Prettier, and Tailwind configuration for the Chorus monorepo. CODING_STANDARDS.md: 'ESLint and Prettier configs live in packages/config and are never overridden per-app.'",
  "exports": {
    "./prettier": "./prettier.js",
    "./tailwind-preset": "./tailwind-preset.ts",
    "./eslint-config": "./eslint-config/index.js",
    "./eslint-config/nextjs": "./eslint-config/nextjs.js",
    "./tsconfig/base": "./tsconfig.base.json",
    "./tsconfig/nextjs": "./tsconfig.nextjs.json",
    "./tsconfig/node": "./tsconfig.node.json"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.11.1",
    "eslint-config-next": "^15.0.0",
    "eslint-plugin-import": "^2.31.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
