# Root-level environment variables
# Copy to .env.local and fill in values for local development.
# Production secrets are managed via Doppler — see SECURITY_MODEL.md.
# Never commit .env.local or any file with real secret values.

# --- Database ---
DATABASE_URL=

# --- Redis ---
REDIS_URL=

# --- WorkOS (authentication) ---
# Full implementation in v0.3 — placeholder names established here for discoverability
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_WEBHOOK_SECRET=

# --- Doppler (secrets management, CI) ---
DOPPLER_TOKEN=
