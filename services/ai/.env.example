# services/ai environment variables
# Copy to .env and fill values for local development.
# Production secrets managed via Doppler — SECURITY_MODEL.md.

# --- AI service ---
PORT=8000

# --- AI model providers (v0.5+) ---
# AI_ARCHITECTURE.md: "Anthropic/OpenAI per the technology stack"
# AI_ARCHITECTURE.md: "Chorus pursues a BAA with its third-party model provider"
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Voyage AI embeddings (v0.5+) ---
# AI_ARCHITECTURE.md: "Voyage AI's embedding models (Anthropic's recommended embedding partner)"
VOYAGE_AI_API_KEY=

# --- Internal service communication ---
# services/ai calls services/api only to return suggestion objects — never directly writes
CHORUS_API_INTERNAL_URL=http://localhost:4000
