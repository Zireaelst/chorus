generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  type         String   // Enforced via Postgres CHECK constraint
  workosOrgId  String   @unique @map("workos_org_id")
  createdAt    DateTime @default(now()) @map("created_at")

  memberships Memberships[]
  auditLogs   AuditLog[]
  cohorts     Cohort[]
  apiKeys     ApiKey[]
  webhooks    Webhook[]

  @@map("organizations")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  workosUserId String   @unique @map("workos_user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  memberships Memberships[]
  auditLogs   AuditLog[]
  cohorts     Cohort[]
  apiKeys     ApiKey[]

  @@map("users")
}

model Memberships {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  role      String   // Enforced via Postgres CHECK constraint
  createdAt DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)

  @@unique([userId, orgId])
  @@map("memberships")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  eventType   String   @map("event_type")
  metadata    Json
  createdAt   DateTime @default(now()) @map("created_at")

  actor        User         @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)

  @@index([orgId, createdAt])
  @@map("audit_log")
}

model Cohort {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  createdByUserId  String   @map("created_by_user_id") @db.Uuid
  title            String
  criteria         Json
  status           String
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  createdByUser User        @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([orgId, status])
  @@map("cohorts")
}

model ApiKey {
  id               String    @id @default(uuid()) @db.Uuid
  orgId            String    @map("org_id") @db.Uuid
  name             String
  keyHash          String    @unique @map("key_hash")
  createdByUserId  String    @map("created_by_user_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  revokedAt        DateTime? @map("revoked_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  createdByUser User        @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@map("api_keys")
}

model Webhook {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  url         String
  secretHash  String   @map("secret_hash")
  eventTypes  String[] @map("event_types")
  status      String
  createdAt   DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  deliveries   WebhookDelivery[]

  @@map("webhooks")
}

model WebhookDelivery {
  id           String   @id @default(uuid()) @db.Uuid
  webhookId    String   @map("webhook_id") @db.Uuid
  eventType    String   @map("event_type")
  payloadHash  String   @map("payload_hash")
  status       String
  attemptCount Int      @map("attempt_count")
  attemptedAt  DateTime @map("attempted_at")

  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Restrict)

  @@index([status]) // Note: partial index for 'failed' will be added manually
  @@map("webhook_deliveries")
}
