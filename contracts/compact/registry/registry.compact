pragma language_version >= 0.14.0;

import Config from "std";

export ledger routes: Cell<Map<Bytes<32>, Bytes<32>>>;
export ledger owner: Cell<Bytes<32>>;

export circuit init(owner_address: Bytes<32>): [] {
    owner.write(owner_address);
}

export circuit update_route(
    contract_name: Bytes<32>,
    contract_address: Bytes<32>
): [] {
    // assert(global.caller == owner.read(), "Unauthorized: only owner can update routes");
    routes.insert(contract_name, contract_address);
}
