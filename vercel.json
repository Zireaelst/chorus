{
    "services": {
        "web": {
            "root": "apps/web",
            "framework": "nextjs"
        },
        "admin": {
            "root": "apps/admin",
            "framework": "nextjs"
        },
        "ai": {
            "root": "services/ai",
            "framework": "fastapi",
            "entrypoint": "src/main.py"
        },
        "api": {
            "root": "services/api",
            "framework": "nestjs"
        }
    },
    "rewrites": [
        {
            "source": "/api/api(/.*)?",
            "destination": {
                "service": "api"
            }
        },
        {
            "source": "/api/ai(/.*)?",
            "destination": {
                "service": "ai"
            }
        },
        {
            "source": "/admin(/.*)?",
            "destination": {
                "service": "admin"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "service": "web"
            }
        }
    ]
}
